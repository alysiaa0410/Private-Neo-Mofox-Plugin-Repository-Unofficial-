    {
      "signature": "affinity_achievements:command:affinity",
      "type": "command",
      "name": "affinity",
      "description": "查看当前亲密度等级与成就",
      "aliases": ["亲密度", "成就"]
    }
  ],
  "permissions": [
    {
      "node": "affinity_achievements.use",
      "description": "可以使用 /affinity 指令查看亲密度信息"
